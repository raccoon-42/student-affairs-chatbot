# Copy to .env and fill in. Everything has a sane default except the API key.
OPENROUTER_API_KEY=your-openrouter-api-key

# QDRANT_URL=http://localhost:6333
# OLLAMA_URL=http://localhost:11434
# EMBEDDING_BACKEND=openrouter            # or "local" (sentence-transformers)
# OPENROUTER_EMBEDDING_MODEL=google/gemini-embedding-2
# EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct   # used when EMBEDDING_BACKEND=local
# CALENDAR_COLLECTION=academic_calendar_2025
# REGULATIONS_COLLECTION=regulations
# OPENROUTER_MODEL=anthropic/claude-sonnet-5
# OLLAMA_MODEL=gemma3:4b
# JUDGE_MODEL=anthropic/claude-sonnet-5
# GUARD_MODEL=anthropic/claude-haiku-4.5
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com   # enables Google Sign-In in the web UI
# ABUSE_EXEMPT=127.0.0.1,you@gmail.com               # dev bypass for the abuse block only
# CALENDAR_SOURCE_URL=https://...                    # "view sources" link for calendar chunks
# REGULATIONS_SOURCE_URL=https://...                 # "view sources" link for regulation chunks
