# Copy to .env and fill in. Everything has a sane default except the API key.
OPENROUTER_API_KEY=your-openrouter-api-key

# --- LLM ---
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# ALLOWED_CHAT_MODELS=anthropic/claude-haiku-4.5,anthropic/claude-sonnet-5   # model_name values the API accepts
# JUDGE_MODEL=anthropic/claude-sonnet-5
# GUARD_MODEL=anthropic/claude-haiku-4.5
# LLM_MAX_TOKENS=2048
# LLM_CONTEXT_WINDOW=200000                                                  # for the UI context-fill %
# LLM_TIMEOUT_SECONDS=90

# --- Embeddings ---
# EMBEDDING_BACKEND=openrouter            # or "local" (sentence-transformers)
# OPENROUTER_EMBEDDING_MODEL=google/gemini-embedding-2
# EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct   # used when EMBEDDING_BACKEND=local

# --- Qdrant collections ---
# QDRANT_URL=http://localhost:6333
# CALENDAR_COLLECTION=calendar
# REGULATIONS_COLLECTION=regulations
# FAQ_COLLECTION=faq
# FORMS_COLLECTION=forms
# SKS_COLLECTION=sks
# PROGRAMS_COLLECTION=programs
# PEOPLE_COLLECTION=people
# COURSES_COLLECTION=courses
# GUIDES_COLLECTION=guides

# --- Speech-to-text (mic button hidden when unset) ---
# GROQ_API_KEY=your-groq-api-key
# GROQ_WHISPER_MODEL=whisper-large-v3

# --- Auth / persistence ---
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com   # enables Google Sign-In in the web UI
# ADMIN_EMAILS=you@gmail.com                        # may read /admin/usage; empty disables it
# DB_PATH=data/app.db
# COOKIE_SECURE=1                                   # set behind HTTPS in production

# --- Rate limits / abuse ---
# CHAT_LIMIT_ANON=5
# CHAT_LIMIT_USER=60
# STT_LIMIT=30
# CHAT_REFUSAL_LIMIT=3
# ABUSE_BLOCK_MINUTES=10
# ABUSE_EXEMPT=127.0.0.1,you@gmail.com              # dev bypass for the abuse block only
# RATELIMIT_EXEMPT=127.0.0.1,you@gmail.com          # dev bypass for chat/STT limits

# --- Frontend ---
# API_URL=http://localhost:8000
